# Portkey gateway — routes all LLM calls (pipeline agents + chat)
# Get your API key at https://portkey.ai
PORTKEY_API_KEY=

# Virtual key pointing to your Anthropic API key (pipeline agents)
# or your OpenAI API key (chat) — configure in the Portkey dashboard
PORTKEY_VIRTUAL_KEY=

# SQLite database path (created automatically on first run)
DATABASE_URL=./data/jobs.db

# Temp directory for cloned repos (cleaned up after each job)
CLONE_DIR=/tmp/ecb-jobs
