# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Environment variables — never commit secrets ─────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# .env.local.example is intentionally NOT ignored (safe template)

# ─── Database — SQLite file lives here ────────────────────────────────────────
/data/
*.db
*.sqlite
*.sqlite3

# ─── Pipeline temp clones ─────────────────────────────────────────────────────
/tmp/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
*.pem
Thumbs.db

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Debug / logs ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── Test & coverage ──────────────────────────────────────────────────────────
/coverage
.nyc_output/

# ─── Playwright browser automation artifacts ──────────────────────────────────
/.playwright-mcp/
/test-results/
/playwright-report/

# ─── Generated screenshots (dev artefacts) ───────────────────────────────────
*.png
*.jpeg
!public/**/*.png
!public/**/*.jpg
!public/**/*.jpeg

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Deploy ───────────────────────────────────────────────────────────────────
.vercel
.turbo
